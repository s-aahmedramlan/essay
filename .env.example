BASE_URL=http://localhost:3000
SESSION_SECRET=change-this-secret

# Paid access: Cognito (auth) + DynamoDB (you mark students as paid)
# Get these from Cognito → User pools → your pool → User pool ID / App client ID
COGNITO_USER_POOL_ID=us-east-2_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# DynamoDB table name (create in AWS Console; partition key: email (String))
ACCESS_TABLE_NAME=essaybros-access
AWS_REGION=us-east-2

# ZeptoMail (free, sends to any email – no domain needed)
# Sign up: https://www.zoho.com/zeptomail/
# Add sender email and verify it, then copy your Send Mail Token from Agents → SMTP/API
ZEPTOMAIL_TOKEN=your_send_mail_token_here
ZEPTOMAIL_FROM_EMAIL=your-verified-sender@example.com
ZEPTOMAIL_FROM_NAME=Essay Bros
